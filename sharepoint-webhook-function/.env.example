# ─────────────────────────────────────────────────────────────────────────────
# SharePoint Webhook Azure Function – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (local development) or set these as Application
# Settings in your Azure Function App.
# NEVER commit the .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AD / App Registration ───────────────────────────────────────────────
TENANT_ID=<your-tenant-id-guid>
CLIENT_ID=<your-app-registration-client-id-guid>
CLIENT_SECRET=<your-client-secret-value>

# Certificate authentication (alternative to CLIENT_SECRET)
# CERTIFICATE_PATH=C:\certs\myapp.pfx
# CERTIFICATE_PASSWORD=<pfx-password>
# CERTIFICATE_THUMBPRINT=<cert-thumbprint>

# ── SharePoint ────────────────────────────────────────────────────────────────
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
SHAREPOINT_LIST_ID=<list-id-guid>
SHAREPOINT_LIST_NAME=<list-display-name>

# Shared secret echoed back in webhook notifications for validation
WEBHOOK_CLIENT_STATE=<random-secure-string>

# ── Azure Function ────────────────────────────────────────────────────────────
# Required by the Functions runtime
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=dotnet

# Optional: connection string for async queue processing
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ── Logging / Monitoring ──────────────────────────────────────────────────────
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>
